// Back Channel — Broker DB schema
//
// See docs/production-architecture.md for the data-model rationale.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id              String   @id @default(uuid())
  handle          String   @unique
  email           String   @unique
  displayName     String?
  agentPubkey     String?
  agentEndpoint   String?
  apiKey         String?   @unique
  apiKeyLastUsedAt DateTime?              // dashboard "last used"; touched (throttled) by getAccountFromAuth
  createdAt       DateTime @default(now())
  emailVerifiedAt DateTime?
  notifyIdleFrames Boolean @default(true) // email me when a frame arrives while I'm idle
  favorPerPeerDaily    Int @default(5)     // max favors I'll accept from one peer per day
  favorGlobalTokensDaily Int @default(50000) // max borrowed-compute tokens/day across all peers
  liveModeDefaultMinutes Int @default(15)  // default live-mode window when a thread opts into real-time (inbox-model pivot)
  inboxCheckEnabled Boolean @default(true) // agent's bc-inbox-check should run (it reads this each cycle; false → self-remove)
  inboxCheckMinutes Int @default(10)       // cadence (minutes) the agent's bc-inbox-check should use
  admin            Boolean @default(false) // operator: can read metadata-only analytics (never content)

  invitesAsHost    Invite[]  @relation("HostInvites")
  invitesAsVisitor Invite[]  @relation("VisitorInvites")
  viewTokens       ViewToken[]
  sessionCookies   SessionCookie[]
  accountAudits    AccountAudit[]
  trustGiven       TrustedPeer[] @relation("TrustOwner")
  trustReceived    TrustedPeer[] @relation("TrustPeer")
  inboxReceived    InboxRequest[] @relation("InboxRecipient")
  inboxSent        InboxRequest[] @relation("InboxRequester")
  userSkills       UserSkill[]
  skillSharesRecv  SkillShare[]   @relation("SkillShareWith")
  skillInvocations SkillInvocation[]
  skillImports     SkillImport[]
  favorsReceived   FavorLog[]     @relation("FavorRecipient")
  favorsRequested  FavorLog[]     @relation("FavorRequester")
  favorMutes       FavorMute[]    @relation("FavorMuter")
  agentPayloads    AgentPayload[]
  exchangeCodes    ExchangeCode[]
  agentTokens      AgentToken[]
}

// Per-agent API tokens (per-agent-tokens Phase 1). Each connected agent gets its
// OWN bc_ key tied to the same account, individually revocable (GitHub-PAT style).
// Only the hash is stored. The legacy single Account.apiKey is backfilled into a
// row named "Original" and stays as an auth fallback for one deploy.
enum RuntimeType {
  cowork
  codex
  claude_code
  chatgpt
  other
}

model AgentToken {
  id          String      @id @default(uuid())
  accountId   String
  keyHash     String      @unique           // sha256(bc_ key); raw never stored
  name        String                          // user label, e.g. "Loby on home PC"
  runtimeType RuntimeType @default(other)
  createdAt   DateTime    @default(now())
  lastUsedAt  DateTime?                        // touched (throttled) on each authed request
  revokedAt   DateTime?                        // set on revoke; auth requires revokedAt IS NULL
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([accountId, revokedAt])
}

// Exchange-code flow (device-code pattern): keeps raw bc_ keys out of LLM chat
// transcripts. The dashboard mints a short-lived single-use code; the user
// pastes ONLY the code to their agent; the agent exchanges it (no auth header)
// for the account's real apiKey. Code is hashed at rest and dead within 60s.
model ExchangeCode {
  codeHash    String      @id            // sha256(raw); raw is never stored
  accountId   String
  purpose     String      @default("exchange")
  agentName   String?                    // names the AgentToken minted on redemption
  runtimeType RuntimeType  @default(other)
  createdAt   DateTime    @default(now())
  expiresAt   DateTime                   // createdAt + 60s
  usedAt      DateTime?
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

// Self-inbox "deliver this to my own agent" channel (inbox-model pivot §5). A
// generic envelope a user drops for their OWN agent to pick up on its next
// bc-inbox-check. Phase 1 kind="skill": a reference to a skill a trusted peer
// shared with the user (the broker already holds that share, so `ref` exposes
// nothing new and isn't sealed). The future clipper (v1.x) will use a sealed
// kind where the broker stores only an opaque blob. Always self-addressed, so
// it adds no inbound-spam surface.
model AgentPayload {
  id          String    @id @default(uuid())
  accountId   String                  // owner = recipient = the only addressee (self)
  kind        String                  // "skill" (Phase 1)
  ref         Json                    // {skillId, name, skillKind, ownerHandle}
  note        String?
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?               // set when the agent has pulled it
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, deliveredAt])
}

// Favors — delegate a task to a trusted peer's agent (runs on THEIR compute).
// The task + result are sealed agent frames (favor.request/favor.response,
// content-blind). The broker holds only METADATA: an audit/counter log (for the
// per-peer + global daily caps and the reciprocity view) and the mute list.
model FavorLog {
  id                 String   @id @default(uuid())
  recipientAccountId String                  // who did the favor (spent compute)
  requesterAccountId String                  // who asked
  status             String                  // accepted | declined | completed
  tokensUsed         Int      @default(0)
  at                 DateTime @default(now())
  recipient Account @relation("FavorRecipient", fields: [recipientAccountId], references: [id], onDelete: Cascade)
  requester Account @relation("FavorRequester", fields: [requesterAccountId], references: [id], onDelete: Cascade)

  @@index([recipientAccountId, at])
  @@index([requesterAccountId, recipientAccountId, at])
}

// Time-boxed "mute favors from this peer" without revoking full trust.
model FavorMute {
  accountId      String                       // the muter (recipient)
  mutedAccountId String                       // the peer being muted
  until          DateTime
  account Account @relation("FavorMuter", fields: [accountId], references: [id], onDelete: Cascade)

  @@id([accountId, mutedAccountId])
}

// Skill Sharing (shared capabilities). A user-owned capability the owner's agent
// can run. Tier 2-RPC: kind=rpc — runs ONLY on the owner's side during a session
// (the broker stores it, never executes it; body is opaque to the broker).
// kind=template (Tier 2-Template) is copied to a peer; templates must be signed.
enum SkillKind {
  rpc
  template
}

model UserSkill {
  id          String    @id @default(uuid())
  accountId   String
  name        String
  description String?
  kind        SkillKind @default(rpc)
  body        String                  // rpc: local-exec definition; template: shareable instructions
  paramSchema Json?
  signature   String?                 // required for templates (author signature)
  discoverable Boolean  @default(false) // Tier 2.5: NAME+description visible to my trusted peers (discovery != access)
  version     Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  shares      SkillShare[]

  @@index([accountId])
}

model SkillShare {
  skillId             String
  sharedWithAccountId String
  sharedBy            String          // owner accountId (audit)
  sharedAt            DateTime @default(now())
  skill        UserSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  sharedWith   Account   @relation("SkillShareWith", fields: [sharedWithAccountId], references: [id], onDelete: Cascade)

  @@id([skillId, sharedWithAccountId])
  @@index([sharedWithAccountId])
}

model SkillInvocation {
  id                 String   @id @default(uuid())
  skillId            String
  invokedByAccountId String
  sessionId          String
  result             String?         // status/metadata only — never the underlying data
  at                 DateTime @default(now())
  invokedBy Account @relation(fields: [invokedByAccountId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([sessionId])
}

// Tier 2-Template: an audit record that an account imported a (signed) template.
// The actual copy lives on the importer's LOCAL agent — this is provenance +
// the basis for an "uninstall" (reversible imports, skill-sharing-epic §8.2).
model SkillImport {
  id                  String   @id @default(uuid())
  skillId             String                  // source skill (author's)
  importedByAccountId String
  importedAt          DateTime @default(now())
  importedBy Account @relation(fields: [importedByAccountId], references: [id], onDelete: Cascade)

  @@unique([skillId, importedByAccountId])
  @@index([importedByAccountId])
}

// Inbox (Account Dashboard Wave 3). A mutually-trusted peer's agent drops a
// session request here; the recipient approves/declines from the dashboard.
// Trust waived the invite CODE, not the per-session scope approval — accepting
// mints a normal Invite+Session (requester=visitor, recipient=host).
enum InboxStatus {
  pending
  accepted
  rejected
  expired
}

model InboxRequest {
  id                 String      @id @default(uuid())
  recipientAccountId String
  requesterAccountId String
  requestedScopes    String[]
  message            String?
  status             InboxStatus @default(pending)
  sessionId          String?     // set when accepted (the minted session)
  createdAt          DateTime    @default(now())
  expiresAt          DateTime    // createdAt + 24h
  resolvedAt         DateTime?
  recipient Account @relation("InboxRecipient", fields: [recipientAccountId], references: [id], onDelete: Cascade)
  requester Account @relation("InboxRequester", fields: [requesterAccountId], references: [id], onDelete: Cascade)

  @@index([recipientAccountId, status])
  @@index([expiresAt])
}

// Trust (Account Dashboard Wave 2). DIRECTED: one row = "this account trusts
// that peer." Mutual trust (required to actually collaborate code-free) = both
// directed rows present. Per the resolved spec it's a dashboard enable/disable
// toggle: eligibility = the pair has had a real session before; enabling
// creates this row, revoking deletes it. accountId-keyed (survives handle
// changes; never transfers on handle reissue).
model TrustedPeer {
  id               String   @id @default(uuid())
  accountId        String   // the owner of this trust record
  trustedAccountId String   // the peer they trust
  establishedAt    DateTime @default(now())
  lastUsedAt       DateTime?
  scopeDefaults    String[] // ceiling for what this peer may request via inbox (Wave 3)
  account        Account @relation("TrustOwner", fields: [accountId],        references: [id], onDelete: Cascade)
  trustedAccount Account @relation("TrustPeer",  fields: [trustedAccountId], references: [id], onDelete: Cascade)

  @@unique([accountId, trustedAccountId])  // one directed row per pair
  @@index([accountId])
  @@index([trustedAccountId])
}

// Account Dashboard — short-lived, single-use token emailed to a verified
// account; exchanged at /api/auth/view-verify for a browser session cookie.
// Lets a human reach /account from email without pasting their bearer key.
model ViewToken {
  token     String   @id            // random urlsafe ("vt_...")
  accountId String
  purpose   String   @default("account") // "account" | "session:<id>" deep-link hint
  createdAt DateTime @default(now())
  expiresAt DateTime                 // createdAt + 15 min
  usedAt    DateTime?
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

// Server-side browser session backing the httpOnly `bc_session` cookie. Grants
// the human dashboard tier (view/manage), a strict subset of the agent bearer
// key (cannot create invites / claim / poll / send).
model SessionCookie {
  token      String   @id            // random urlsafe ("cs_..."); value of bc_session cookie
  accountId  String
  createdAt  DateTime @default(now())
  expiresAt  DateTime                 // createdAt + 24h
  lastUsedAt DateTime?
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

// Account-scoped audit (distinct from session-scoped AuditLog, which is FK-bound
// to a collaboration Session). Holds dashboard/account events: view-token.issued,
// view-token.consumed, key.rotated, trust.revoked, session.ended_manually, etc.
model AccountAudit {
  id        BigInt   @id @default(autoincrement())
  accountId String
  ts        DateTime @default(now())
  eventType String
  detail    Json     // metadata only — never plaintext content
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([ts])
}

model Invite {
  id                 String   @id @default(uuid())
  code               String   @unique
  hostAccountId      String
  visitorAccountId   String
  scopes             String[]
  ttlMinutes         Int
  message            String?
  status             InviteStatus @default(pending)
  createdAt          DateTime @default(now())
  expiresAt          DateTime
  claimedAt          DateTime?
  confirmedAt        DateTime?

  host    Account @relation("HostInvites",    fields: [hostAccountId],    references: [id])
  visitor Account @relation("VisitorInvites", fields: [visitorAccountId], references: [id])
  session Session?

  @@index([hostAccountId])
  @@index([visitorAccountId])
  @@index([code])
}

enum InviteStatus {
  pending
  claimed
  confirmed
  expired
  kicked
}

model Session {
  id             String   @id @default(uuid())
  inviteId       String   @unique
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  endReason      String?
  scopesGranted  String[]
  liveExpiresAt  DateTime?              // inbox-model pivot: when set + future, this thread is in opt-in real-time (live) mode; agents poll fast until it lapses, then revert to async inbox cadence

  invite     Invite     @relation(fields: [inviteId], references: [id])
  auditLog   AuditLog[]
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  sessionId String
  ts        DateTime @default(now())
  role      String   // "visitor" | "host"
  eventType String
  detail    Json     // redacted — no plaintext content

  session Session @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([ts])
}

model MagicLink {
  token       String   @id
  email       String
  expiresAt   DateTime
  consumedAt  DateTime?
  claimCode   String?  // M1: if set, auto-claim this invite for the account right after verify

  @@index([email])
  @@index([expiresAt])
}

// Relay frame buffer, persisted so an in-flight session survives a broker
// restart/redeploy (the in-memory globalThis buffer is rebuilt from here on the
// first poll/connect after restart). Capped per (session, roleDest) at the same
// 512-frame limit as memory; trimmed on eviction; purged when the session ends.
// Bodies are the relayed frames (ideally end-to-end ciphertext) — transient,
// not a long-term store.
model Frame {
  id        BigInt   @id @default(autoincrement())
  sessionId String
  roleDest  String   // "visitor" | "host" — the role this frame is addressed TO
  seq       Int      // per-(session, roleDest) sequence number
  body      String
  createdAt DateTime @default(now())

  @@unique([sessionId, roleDest, seq])
  @@index([sessionId, roleDest, seq])
}


